# Portable AV deployment environment.
# Copy to /etc/portable-av/portable-av.env and adjust for your install.

# Production layout:
# PORTABLE_AV_INSTALL_DIR=/opt/portable-av
# PORTABLE_AV_PYTHON=/opt/portable-av/.venv/bin/python
# PORTABLE_AV_RUNTIME=/run/portable-av

# Development layout (home checkout):
PORTABLE_AV_INSTALL_DIR=/home/radxa03virus/portable-antivirus
PORTABLE_AV_PYTHON=/home/radxa03virus/portable-antivirus/.venv/bin/python
PORTABLE_AV_RUNTIME=/home/radxa03virus/portable-antivirus/var/run/portable-av

PORTABLE_AV_API_HOST=127.0.0.1
PORTABLE_AV_API_PORT=8080

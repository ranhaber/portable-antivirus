<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Scan report {{ scan_id }}</title>
  <style>
    body { font-family: sans-serif; margin: 2rem; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 0.5rem; text-align: left; }
    th { background: #f5f5f5; }
  </style>
</head>
<body>
  <h1>Scan report {{ scan_id }}</h1>
  <p><strong>Mode:</strong> {{ scan.mode }}</p>
  <p><strong>Status:</strong> {{ status }}</p>
  <p><strong>Started:</strong> {{ scan.started_at }}</p>
  <p><strong>Ended:</strong> {{ scan.ended_at or "n/a" }}</p>
  <p><strong>Files scanned:</strong> {{ scan.files_scanned }}</p>
  <p><strong>Bytes scanned:</strong> {{ scan.bytes_scanned }}</p>
  <p><strong>Threats:</strong> {{ threat_count }}</p>
  {% if detections %}
  <h2>Detections</h2>
  <table>
    <thead>
      <tr><th>Engine</th><th>Signature</th><th>File</th></tr>
    </thead>
    <tbody>
      {% for item in detections %}
      <tr>
        <td>{{ item.engine }}</td>
        <td>{{ item.signature }}</td>
        <td>{{ item.file_path }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p>No threats detected.</p>
  {% endif %}
</body>
</html>
